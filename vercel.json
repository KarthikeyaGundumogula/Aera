{
  "rewrites": [
    {
      "source": "/originals/(.*)",
      "destination": "/api/metadata"
    },
    {
      "source": "/works/(.*)",
      "destination": "/api/metadata"
    },
    {
      "source": "/festivals/(.*)",
      "destination": "/api/metadata"
    },
    {
      "source": "/sets/(.*)",
      "destination": "/api/metadata"
    },
    {
      "source": "/artists/(.*)",
      "destination": "/api/metadata"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {

          "key": "X-Frame-Options",
          "value": "SAMEORIGIN"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "Permissions-Policy",
          "value": "camera=(), microphone=(), geolocation=()"
        }
      ]
    }
  ]
}
